<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <!-- 标题：DATE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/date"
        android:textSize="20sp"
        android:textColor="#000000"
        android:fontFamily="montserrat"
        android:textStyle="bold"
        android:letterSpacing="-0.187"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:textAllCaps="true" />

    <!-- 滚轮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp">

        <NumberPicker
            android:id="@+id/np_month"
            android:layout_width="0dp"
            android:layout_height="238.5dp"
            android:layout_weight="1"
            android:paddingVertical="7dp" />

        <NumberPicker
            android:id="@+id/np_day"
            android:layout_width="0dp"
            android:layout_height="238.5dp"
            android:layout_weight="1"
            android:paddingVertical="7dp" />

        <NumberPicker
            android:id="@+id/np_year"
            android:layout_width="0dp"
            android:layout_height="238.5dp"
            android:layout_weight="1"
            android:paddingVertical="7dp" />
    </LinearLayout>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/cancel"
            android:textSize="16sp"
            android:textColor="#000000"
            android:background="@color/bg_rounded_gray"
            android:fontFamily="montserrat"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_done"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/done"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@color/bg_rounded_blue"
            android:fontFamily="montserrat"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>