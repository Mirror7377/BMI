<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="345dp"
    android:layout_height="90dp"
    android:background="@drawable/bg_recent_card"
    android:layout_marginTop="15dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- BMI 数值（大号） -->
    <TextView
        android:id="@+id/tvBmiValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:text="0.0"
        android:textColor="#000000"
        android:textSize="27sp"
        android:fontFamily="@font/montserrat_extrabold"
        android:letterSpacing="-0.00938"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 彩色圆点 -->
    <View
        android:id="@+id/dotLevel"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="59.5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvLevelName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="Normal"
        android:textColor="#000000"
        android:textSize="16sp"
        android:fontFamily="@font/montserrat_regular"
        app:layout_constraintStart_toEndOf="@id/dotLevel"
        app:layout_constraintTop_toTopOf="@id/dotLevel"
        app:layout_constraintBottom_toBottomOf="@id/dotLevel"/>

    <!-- 日期 + 时段 -->
    <TextView
        android:id="@+id/tvDateTime"
        android:layout_width="83dp"
        android:layout_height="wrap_content"
        android:text="May 6, 2021\nMorning"
        android:textColor="#444444"
        android:textSize="15sp"
        android:fontFamily="@font/montserrat_regular"
        android:letterSpacing="-0.00881"
        android:gravity="end|center_vertical"
        android:lineSpacingExtra="2dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@id/ivArrow"
        app:layout_constraintTop_toTopOf="@id/ivArrow"
        app:layout_constraintBottom_toBottomOf="@id/ivArrow"/>

    <!-- 右箭头 -->
    <ImageView
        android:id="@+id/ivArrow"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="31dp"
        android:layout_marginEnd="24dp"
        android:src="@drawable/arrow_right"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>