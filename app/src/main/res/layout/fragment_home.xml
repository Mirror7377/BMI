<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAEAEE">

    <!-- ========== 顶部导航栏（未改动） ========== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/navBar"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginTop="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvCalculator"
            android:layout_width="135dp"
            android:layout_height="24dp"
            android:text="@string/calculator"
            android:textColor="#000"
            android:textSize="24sp"
            app:fontFamily="@font/montserrat_extrabold"
            android:includeFontPadding="false"
            android:gravity="start|center_vertical"
            android:layout_marginTop="18dp"
            android:layout_marginStart="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/ivPerson"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_person"
            android:scaleType="centerInside"
            android:layout_marginTop="17dp"
            android:layout_marginBottom="17dp"
            android:layout_marginStart="336dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ========== 中轴线（50% 位置） ========== -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_middle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- ========== Weight 标签（左半区居中） ========== -->
    <TextView
        android:id="@+id/tvWeight"
        android:layout_width="56.5dp"
        android:layout_height="17dp"
        android:text="Weight"
        android:textColor="#000000"
        android:textSize="14sp"
        app:fontFamily="@font/montserrat_regular"
        android:textStyle="normal"
        android:gravity="center"
        android:layout_marginTop="102dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_middle"
        app:layout_constraintHorizontal_bias="0.5" />

    <!-- ========== Height 标签（右半区居中） ========== -->
    <TextView
        android:id="@+id/tvHeight"
        android:layout_width="48dp"
        android:layout_height="17dp"
        android:text="Height"
        android:textColor="#000000"
        android:textSize="14sp"
        app:fontFamily="@font/montserrat_regular"
        android:textStyle="normal"
        android:gravity="center"
        android:layout_marginTop="102dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideline_middle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5" />

    <!-- ========== 体重容器（与身高组构成链条） ========== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/weightContainer"
        android:layout_width="160dp"
        android:layout_height="68dp"
        android:layout_marginTop="134dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/heightGroupContainer"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintHorizontal_bias="0.5">

        <EditText
            android:id="@+id/etWeightValue"
            android:layout_width="91dp"
            android:layout_height="37dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="35dp"
            android:text="140.00"
            android:textColor="#000000"
            android:textSize="25sp"
            android:fontFamily="@font/montserrat_extrabold"
            android:textAlignment="center"
            android:gravity="center"
            android:includeFontPadding="false"
            android:background="@null"
            android:inputType="numberDecimal"
            android:maxLength="6"
            android:imeOptions="actionDone"
            android:importantForAutofill="no" />
    </androidx.cardview.widget.CardView>

    <!-- ========== 身高组父容器（包裹两种模式） ========== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/heightGroupContainer"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="134dp"
        android:layout_marginStart="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/weightContainer"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 模式1：ft-in -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/heightFtInGroup"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/ftContainer"
                android:layout_width="70dp"
                android:layout_height="68dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="0dp"
                android:backgroundTint="#FFFFFF"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etFtValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textColor="#000000"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:background="@null"
                        android:inputType="number"
                        android:maxLength="1"
                        android:imeOptions="actionDone"
                        android:paddingEnd="2dp"
                        android:minWidth="20dp" />

                    <TextView
                        android:id="@+id/tvFtSymbol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/etFtValue"
                        android:layout_alignBaseline="@id/etFtValue"
                        android:text="'"
                        android:textColor="#000000"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:paddingStart="2dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/inContainer"
                android:layout_width="84.5dp"
                android:layout_height="68dp"
                android:layout_marginStart="5.5dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="0dp"
                android:backgroundTint="#FFFFFF"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/ftContainer">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etInValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7"
                        android:textColor="#000000"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:background="@null"
                        android:inputType="number"
                        android:maxLength="2"
                        android:imeOptions="actionDone"
                        android:paddingEnd="2dp"
                        android:minWidth="30dp" />

                    <TextView
                        android:id="@+id/tvInSymbol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/etInValue"
                        android:layout_alignBaseline="@id/etInValue"
                        android:text="&quot;"
                        android:textColor="#000000"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:paddingStart="2dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 模式2：cm -->
        <androidx.cardview.widget.CardView
            android:id="@+id/heightCmGroup"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:visibility="gone"
            app:cardCornerRadius="15dp"
            app:cardElevation="0dp"
            android:backgroundTint="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <EditText
                android:id="@+id/etCmValue"
                android:layout_width="83dp"
                android:layout_height="37dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="41.5dp"
                android:text="170.0"
                android:textColor="#000000"
                android:textSize="30sp"
                android:fontFamily="@font/montserrat_extrabold"
                android:letterSpacing="-0.00937"
                android:textAlignment="center"
                android:gravity="center"
                android:includeFontPadding="false"
                android:background="@null"
                android:inputType="numberDecimal"
                android:maxLength="5"
                android:imeOptions="actionDone" />
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ========== 单位切换容器（链条居中） ========== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/unitSwitchContainer"
        android:layout_width="160dp"
        android:layout_height="36dp"
        android:layout_marginTop="212dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        android:backgroundTint="#F5F5F7"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/heightUnitSwitchContainer"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintHorizontal_bias="0.5">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/selectedUnitBg"
                android:layout_width="90dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_white_selected"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="0dp" />

            <TextView
                android:id="@+id/tvUnitLb"
                android:layout_width="40dp"
                android:layout_height="20dp"
                android:layout_marginTop="8.5dp"
                android:layout_marginStart="25dp"
                android:text="lb"
                android:textColor="#000000"
                android:textSize="16sp"
                app:fontFamily="@font/montserrat_extrabold"
                android:letterSpacing="-0.00937"
                android:textAlignment="center"
                android:gravity="center"
                android:includeFontPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvUnitKg"
                android:layout_width="40dp"
                android:layout_height="20dp"
                android:layout_marginTop="8.5dp"
                android:layout_marginStart="95dp"
                android:text="kg"
                android:textColor="#000000"
                android:textSize="16sp"
                app:fontFamily="@font/montserrat_extrabold"
                android:letterSpacing="-0.00937"
                android:textAlignment="center"
                android:gravity="center"
                android:includeFontPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/heightUnitSwitchContainer"
        android:layout_width="160dp"
        android:layout_height="36dp"
        android:layout_marginTop="212dp"
        android:layout_marginStart="15dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        android:backgroundTint="#F5F5F7"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/unitSwitchContainer"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/selectedUnitBgHeight"
                android:layout_width="90dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_white_selected"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="0dp" />

            <TextView
                android:id="@+id/tvUnitFtIn"
                android:layout_width="40dp"
                android:layout_height="20dp"
                android:layout_marginTop="8.5dp"
                android:layout_marginStart="25dp"
                android:text="ft-in"
                android:textColor="#000000"
                android:textSize="16sp"
                app:fontFamily="@font/montserrat_extrabold"
                android:letterSpacing="-0.00937"
                android:textAlignment="center"
                android:gravity="center"
                android:includeFontPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvUnitCm"
                android:layout_width="30dp"
                android:layout_height="20dp"
                android:layout_marginTop="8.5dp"
                android:layout_marginStart="95dp"
                android:text="cm"
                android:textColor="#000000"
                android:textSize="16sp"
                app:fontFamily="@font/montserrat_extrabold"
                android:letterSpacing="-0.00937"
                android:textAlignment="center"
                android:gravity="center"
                android:includeFontPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- ========== 日期 / 时段选择容器（链条居中） ========== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/datePickerContainer"
        android:layout_width="160dp"
        android:layout_height="60dp"
        android:layout_marginTop="310dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp"
        android:backgroundTint="#FFFFFF"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/timeOfDayPickerContainer"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintHorizontal_bias="0.5">

        <TextView
            android:id="@+id/tvDateDisplay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="@font/montserrat_extrabold"
            android:gravity="center"
            android:text="Today"
            android:textColor="#000000"
            android:textSize="20sp" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/timeOfDayPickerContainer"
        android:layout_width="160dp"
        android:layout_height="60dp"
        android:layout_marginTop="310dp"
        android:layout_marginStart="15dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp"
        android:backgroundTint="#FFFFFF"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/datePickerContainer"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTimeOfDayDisplay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Morning"
            android:textColor="#000000"
            android:textSize="20sp"
            android:fontFamily="@font/montserrat_extrabold" />
    </androidx.cardview.widget.CardView>

    <!-- ========== Time 标签（已居中，保持不变） ========== -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="35dp"
        android:layout_height="17dp"
        android:text="Time"
        android:textColor="#000000"
        android:textSize="14sp"
        app:fontFamily="@font/montserrat_regular"
        android:textStyle="normal"
        android:gravity="center"
        android:layout_marginTop="278dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ========== Age 标签 ========== -->
    <TextView
        android:id="@+id/tvAge"
        android:layout_width="28dp"
        android:layout_height="17dp"
        android:text="Age"
        android:textColor="#000000"
        android:textSize="14sp"
        app:fontFamily="@font/montserrat_regular"
        android:textStyle="normal"
        android:textAlignment="textEnd"
        android:gravity="end|center_vertical"
        android:layout_marginTop="400dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ========== 年龄滚轮容器（已居中） ========== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/valuesContainer"
        android:layout_width="335dp"
        android:layout_height="72dp"
        android:layout_marginTop="432dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="307dp"
            android:layout_height="39dp"
            android:layout_gravity="center">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAgePicker"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- ========== 蓝色三角（已居中） ========== -->
    <View
        android:id="@+id/colorBlock"
        android:layout_width="15dp"
        android:layout_height="11dp"
        android:background="@drawable/ic_triangle_blue"
        android:layout_marginTop="493dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ========== 性别容器（链条居中，已实现） ========== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/genderContainer1"
        android:layout_width="160dp"
        android:layout_height="90dp"
        android:layout_marginTop="519dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/genderContainer2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintHorizontal_bias="0.5">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/genderIcon1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/ic_male"
                android:layout_marginTop="20dp"
                android:layout_marginStart="63dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/genderText1"
                android:layout_width="34dp"
                android:layout_height="17dp"
                android:text="Male"
                android:textColor="#000000"
                android:textSize="14sp"
                app:fontFamily="@font/montserrat_regular"
                android:textStyle="normal"
                android:letterSpacing="-0.00936"
                android:textAlignment="center"
                android:gravity="center"
                android:includeFontPadding="false"
                android:layout_marginTop="58dp"
                android:layout_marginStart="63.5dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:id="@+id/genderCheck1"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="6dp"
                android:layout_marginStart="135dp"
                android:src="@drawable/check_circle"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/genderContainer2"
        android:layout_width="160dp"
        android:layout_height="90dp"
        android:layout_marginTop="519dp"
        android:layout_marginStart="15dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintStart_toEndOf="@+id/genderContainer1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/genderIcon2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/ic_female"
                android:layout_marginTop="20dp"
                android:layout_marginStart="63dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/genderText2"
                android:layout_width="52dp"
                android:layout_height="17dp"
                android:text="Female"
                android:textColor="#000000"
                android:textSize="14sp"
                app:fontFamily="@font/montserrat_regular"
                android:textStyle="normal"
                android:letterSpacing="-0.00936"
                android:textAlignment="center"
                android:gravity="center"
                android:includeFontPadding="false"
                android:layout_marginTop="58dp"
                android:layout_marginStart="54.5dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:id="@+id/genderCheck2"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="6dp"
                android:layout_marginStart="135dp"
                android:src="@drawable/check_circle"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- ========== Calculate 按钮（已居中） ========== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnCalculate"
        android:layout_width="345dp"
        android:layout_height="57.5dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#3659CF"
        app:cardCornerRadius="28.75dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCalculate"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="CALCULATE"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:gravity="center"
            android:includeFontPadding="false"
            app:fontFamily="@font/montserrat_extrabold" />
    </androidx.cardview.widget.CardView>

    <!-- ========== 底部导航栏（未改动，保留） ========== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavBar"
