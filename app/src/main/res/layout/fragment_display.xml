<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- BMI 数值（小号） -->
    <TextView
        android:id="@+id/tvBmiValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BMI"
        android:textColor="#000000"
        android:textSize="24sp"
        android:fontFamily="@font/montserrat_extrabold"
        android:lineHeight="22sp"
        android:layout_marginTop="18dp"
        android:layout_marginStart="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 日期 -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No record"
        android:textColor="#000000"
        android:textSize="14sp"
        android:fontFamily="@font/montserrat_regular"
        android:layout_marginTop="50dp"
        android:layout_marginStart="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Recent 按钮 -->
    <TextView
        android:id="@+id/tvRecent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recent"
        android:textColor="#3659CF"
        android:textSize="16sp"
        android:fontFamily="@font/montserrat_regular"
        android:layout_marginTop="19.5dp"
        android:layout_marginEnd="15dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ========== 下方详细内容（有数据时显示） ========== -->
    <ScrollView
        android:id="@+id/scrollViewContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:paddingBottom="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvDate"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- BMI 仪表盘 -->
            <com.example.bmi.ui.bmigauge.BmiGaugeView
                android:id="@+id/bmiGauge"
                android:layout_width="340dp"
                android:layout_height="200dp"
                android:layout_marginTop="0dp"
                android:layout_marginStart="17.5dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- BMI 标题 -->
            <TextView
                android:id="@+id/tvBmiTitle"
                android:layout_width="121dp"
                android:layout_height="22dp"
                android:layout_marginTop="205dp"
                android:text="Your BMI is..."
                android:textColor="#000000"
                android:textSize="16sp"
                android:fontFamily="@font/montserrat_extrabold"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- BMI 数值（大号） -->
            <TextView
                android:id="@+id/tvBmiValueLarge"
                android:layout_width="wrap_content"
                android:layout_height="78dp"
                android:layout_marginTop="225dp"
                android:text="0.0"
                android:textColor="#000000"
                android:textSize="64sp"
                android:fontFamily="@font/montserrat_extrabold"
                android:gravity="center"
                android:includeFontPadding="false"
                android:letterSpacing="-0.009"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- BMI 状态标签容器 -->
            <LinearLayout
                android:id="@+id/statusContainer"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="295dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingLeft="20dp"
                android:paddingRight="20dp">

                <TextView
                    android:id="@+id/tvBmiStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:fontFamily="@font/montserrat_extrabold"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.0094" />

                <ImageView
                    android:id="@+id/statusIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_info_outline"
                    android:layout_marginStart="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- BMI 基础信息 -->
            <TextView
                android:id="@+id/tvBmiInfo"
                android:layout_width="0dp"
                android:layout_height="17dp"
                android:layout_marginTop="350dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:text="71 kg | 180 cm | Male | 25 years old"
                android:textColor="#000000"
                android:textSize="14sp"
                android:fontFamily="@font/montserrat_regular"
                android:gravity="center"
                android:includeFontPadding="false"
                android:letterSpacing="-0.0094"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- BMI 分级图例 -->
            <LinearLayout
                android:id="@+id/llBmiLegend"
                android:layout_width="375dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="380dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Level 0 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutLevel0"
                    android:layout_width="345dp"
                    android:layout_height="27dp"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/dotLevel0"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_legend_dot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8.5dp"
                        android:layout_marginStart="15dp"/>

                    <TextView
                        android:id="@+id/tvLevelName0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Very Severely Underweight"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="35dp"/>

                    <TextView
                        android:id="@+id/tvLevelRange0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="＜16"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="262dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Level 1 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutLevel1"
                    android:layout_width="345dp"
                    android:layout_height="27dp"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/dotLevel1"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_legend_dot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8.5dp"
                        android:layout_marginStart="15dp"/>

                    <TextView
                        android:id="@+id/tvLevelName1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Severely Underweight"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="35dp"/>

                    <TextView
                        android:id="@+id/tvLevelRange1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="16.0-16.9"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="262dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Level 2 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutLevel2"
                    android:layout_width="345dp"
                    android:layout_height="27dp"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/dotLevel2"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_legend_dot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8.5dp"
                        android:layout_marginStart="15dp"/>

                    <TextView
                        android:id="@+id/tvLevelName2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Underweight"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="35dp"/>

                    <TextView
                        android:id="@+id/tvLevelRange2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="17.0-18.4"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="262dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Level 3 (Normal) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutLevel3"
                    android:layout_width="345dp"
                    android:layout_height="27dp"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/dotLevel3"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_legend_dot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8.5dp"
                        android:layout_marginStart="15dp"/>

                    <TextView
                        android:id="@+id/tvLevelName3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="35dp"/>

                    <TextView
                        android:id="@+id/tvLevelRange3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18.5-24.9"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="262dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Level 4 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutLevel4"
                    android:layout_width="345dp"
                    android:layout_height="27dp"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/dotLevel4"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_legend_dot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8.5dp"
                        android:layout_marginStart="15dp"/>

                    <TextView
                        android:id="@+id/tvLevelName4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overweight"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="35dp"/>

                    <TextView
                        android:id="@+id/tvLevelRange4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25.0-29.9"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="262dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Level 5 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutLevel5"
                    android:layout_width="345dp"
                    android:layout_height="27dp"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/dotLevel5"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_legend_dot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8.5dp"
                        android:layout_marginStart="15dp"/>

                    <TextView
                        android:id="@+id/tvLevelName5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Obese Class I"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="35dp"/>

                    <TextView
                        android:id="@+id/tvLevelRange5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30.0-34.9"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="262dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Level 6 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutLevel6"
                    android:layout_width="345dp"
                    android:layout_height="27dp"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/dotLevel6"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_legend_dot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8.5dp"
                        android:layout_marginStart="15dp"/>

                    <TextView
                        android:id="@+id/tvLevelName6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Obese Class II"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="35dp"/>

                    <TextView
                        android:id="@+id/tvLevelRange6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="35.0-39.9"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="262dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Level 7 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutLevel7"
                    android:layout_width="345dp"
                    android:layout_height="27dp">

                    <View
                        android:id="@+id/dotLevel7"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_legend_dot"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="8.5dp"
                        android:layout_marginStart="15dp"/>

                    <TextView
                        android:id="@+id/tvLevelName7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Obese Class III"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_regular"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="35dp"/>

                    <TextView
                        android:id="@+id/tvLevelRange7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="≥40.0"
                        android:textSize="14sp"
                        android:fontFamily="@font/montserrat_extrabold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.0094"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="262dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>